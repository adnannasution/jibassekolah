# Salin file ini jadi .env dan isi sesuai environment kamu.
# Railway otomatis menyediakan DATABASE_URL kalau Postgres plugin sudah ditambahkan.
DATABASE_URL=postgresql://user:password@localhost:5432/jibas_keuangan

# Akun admin pertama -- otomatis dibuat saat aplikasi start KALAU tabel users
# masih kosong. Setelah akun pertama ada, env var ini tidak dipakai lagi
# (aman dibiarkan terisi/dihapus).
ADMIN_LOGIN=admin
ADMIN_NAMA=Administrator
ADMIN_PASSWORD=ganti-dengan-password-kuat
